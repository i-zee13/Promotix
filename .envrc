# Force Homebrew PHP 8.2 in this project (run: direnv allow)
# Remove Herd from PATH, then prepend PHP 8.2
export PATH="$(echo "$PATH" | tr ':' '\n' | grep -v -i herd | tr '\n' ':' | sed 's/:$//')"
if command -v brew >/dev/null 2>&1; then
  export PATH="$(brew --prefix php@8.2)/bin:$(brew --prefix php@8.2)/sbin:$PATH"
fi
